		<!--   =========   Active Object Class   ========  -->
		<ActiveObjectClass>
			<Id>1777266202199</Id>
			<Name><![CDATA[Main]]></Name>
			<AdditionalClassCode><![CDATA[java.util.Random rng;
double[][] baseMatrix;
double[] nodePopulation;
double[][] nodeDistance;
final double BURST_AR = 0.6;
final double NOISE_SD = 0.08;

// ====== Live-LSTM integration state ======
// HTTP client used to talk to the FastAPI prediction service
java.net.http.HttpClient httpClient;
java.time.Duration       httpTimeout = java.time.Duration.ofSeconds(2);

// Pre-QoS matrix (what nature wanted to send) vs post-QoS (what actually flows)
double[][] rawTrafficMatrix;

// Most recent congestion flags from the service
java.util.List<Integer> overloadedDests = new java.util.ArrayList<Integer>();

// Counters for the trace + final summary
int    lstmCallsOk     = 0;
int    lstmCallsFailed = 0;
int    qosActionsTotal = 0;
int    congestionEventsAvoided = 0;
double overflowBefore  = 0.0;
double overflowAfter   = 0.0;]]></AdditionalClassCode>
			<StartupCode><![CDATA[rng = new java.util.Random(seed);

// Allocate state
trafficMatrix   = new double[N][N];
eventMultiplier = new double[N][N];
eventTtl        = new int[N][N];
burstState      = new double[N][N];
for (int i = 0; i < N; i++)
    for (int j = 0; j < N; j++)
        eventMultiplier[i][j] = 1.0;

// Build the gravity-model base matrix
nodePopulation = new double[N];
for (int i = 0; i < N; i++) nodePopulation[i] = 0.3 + 0.7 * rng.nextDouble();

double[][] coords = new double[N][2];
for (int i = 0; i < N; i++) {
    coords[i][0] = 100.0 * rng.nextDouble();
    coords[i][1] = 100.0 * rng.nextDouble();
}
nodeDistance = new double[N][N];
baseMatrix   = new double[N][N];
double maxBase = 0.0;
for (int i = 0; i < N; i++) {
    for (int j = 0; j < N; j++) {
        if (i == j) { nodeDistance[i][j] = 1.0; continue; }
        double dx = coords[i][0] - coords[j][0];
        double dy = coords[i][1] - coords[j][1];
        double d  = Math.sqrt(dx * dx + dy * dy);
        nodeDistance[i][j] = Math.max(d, 1.0);
        double b = (nodePopulation[i] * nodePopulation[j]) / Math.pow(d, 1.2);
        baseMatrix[i][j] = b;
        if (b > maxBase) maxBase = b;
    }
}
// normalise so max base = 1.0
if (maxBase > 0) {
    for (int i = 0; i < N; i++)
        for (int j = 0; j < N; j++)
            baseMatrix[i][j] /= maxBase;
}
for (int i = 0; i < N; i++) baseMatrix[i][i] = 0.0;

// Assign IDs and populations to the node agents
for (int i = 0; i < N; i++) {
    NetworkNode nd = nodes.get(i);
    nd.nodeId = i;
    nd.population = nodePopulation[i];
}

// Allocate the pre-QoS twin matrix
rawTrafficMatrix = new double[N][N];

// Initialise the HTTP client used to call the local FastAPI prediction service.
// IMPORTANT: force HTTP/1.1 — uvicorn doesn't speak HTTP/2 upgrade, and the
// default JDK client tries h2c which causes the server to reject the body.
httpClient = java.net.http.HttpClient.newBuilder()
        .version(java.net.http.HttpClient.Version.HTTP_1_1)
        .connectTimeout(java.time.Duration.ofSeconds(2))
        .build();

openCsv();
traceln("Simulation started: N=" + N + ", interval=" + intervalMin + "min");
traceln("LSTM service URL = " + lstmServiceUrl);
traceln("LSTM integration  = " + (enableLstmCalls ? "ENABLED" : "disabled"));
traceln("QoS strategy      = " + qosStrategy);]]></StartupCode>
			<DestroyCode><![CDATA[closeCsv();
traceln("=== LSTM integration summary ===");
traceln("  predictions OK    : " + lstmCallsOk);
traceln("  predictions FAIL  : " + lstmCallsFailed);
traceln("  QoS actions taken : " + qosActionsTotal);
traceln("  overflow BEFORE   : " + String.format(java.util.Locale.US, "%.3f", overflowBefore));
traceln("  overflow AFTER    : " + String.format(java.util.Locale.US, "%.3f", overflowAfter));
if (overflowBefore > 0) {
    double pct = 100.0 * (overflowBefore - overflowAfter) / overflowBefore;
    traceln("  overflow reduced  : " + String.format(java.util.Locale.US, "%.1f%%", pct));
}]]></DestroyCode>
