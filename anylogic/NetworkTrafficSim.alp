			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1777326694833</Id>
					<Name><![CDATA[onSlotTick]]></Name>
					<X>40</X><Y>390</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// =========================================================
// onSlotTick — one tick = one 15-minute slot.
//
// Closed-loop pipeline:
//   1. age out any active flash-crowd events
//   2. (maybe) trigger a new flash-crowd
//   3. generate THIS slot's raw traffic matrix (pre-QoS)
//   4. ask the LSTM service for predicted-overloaded destinations
//   5. apply QoS to this slot's matrix (post-QoS = what flows)
//   6. write the post-QoS matrix to CSV
// =========================================================

// stop after the configured number of days
if (tIndex >= simulationDays * 24 * 60 / intervalMin) return;

// 1. Advance event TTLs
for (int i = 0; i < N; i++) {
    for (int j = 0; j < N; j++) {
        if (eventTtl[i][j] > 0) eventTtl[i][j]--;
        if (eventTtl[i][j] == 0) eventMultiplier[i][j] = 1.0;
    }
}

// 2. Possibly trigger a flash-crowd event (amplify inbound traffic to a dest)
if (rng.nextDouble() < eventProbability) {
    int dst      = rng.nextInt(N);
    int duration = 2 + rng.nextInt(6);            // 2..7 slots
    double mult  = 1.8 + 1.7 * rng.nextDouble();   // 1.8..3.5x
    for (int i = 0; i < N; i++) {
        if (i == dst) continue;
        eventMultiplier[i][dst] = mult;
        eventTtl[i][dst]        = duration;
    }
    traceln("[t=" + tIndex + "] flash-crowd event → dest=" + dst
            + "  mult=" + String.format("%.2f", mult)
            + "  dur=" + duration);
}

// 3. Compute current traffic matrix (this fills `trafficMatrix`)
generateTrafficForSlot();

// 3b. Snapshot the raw, pre-QoS matrix so we can compare before/after
for (int i = 0; i < N; i++)
    System.arraycopy(trafficMatrix[i], 0, rawTrafficMatrix[i], 0, N);

// 4. Call the prediction service — fills `overloadedDests`
overloadedDests.clear();
if (enableLstmCalls) callPredictionService();

// 5. Slot-level overflow on the raw (pre-QoS) matrix
double[] inboundRaw = new double[N];
for (int i = 0; i < N; i++)
    for (int j = 0; j < N; j++)
        inboundRaw[j] += rawTrafficMatrix[i][j];
double slotOverflowBefore = 0.0;
for (int j = 0; j < N; j++) {
    double cap = nodeCapacity(j);
    if (inboundRaw[j] > cap) slotOverflowBefore += inboundRaw[j] - cap;
}
overflowBefore += slotOverflowBefore;

// 6. Apply QoS to the flagged destinations (modifies `trafficMatrix` in place)
if (!overloadedDests.isEmpty()) applyQosAction();

// 7. Slot-level overflow on the post-QoS matrix
double[] inboundPost = new double[N];
for (int i = 0; i < N; i++)
    for (int j = 0; j < N; j++)
        inboundPost[j] += trafficMatrix[i][j];
double slotOverflowAfter = 0.0;
for (int j = 0; j < N; j++) {
    double cap = nodeCapacity(j);
    if (inboundPost[j] > cap) slotOverflowAfter += inboundPost[j] - cap;
}
overflowAfter += slotOverflowAfter;
if (slotOverflowBefore > slotOverflowAfter + 1e-9) congestionEventsAvoided++;

// 8. Write the post-QoS matrix to CSV — this is the closed loop's output
writeCsvRow();

// 9. Progress log
if (tIndex % 100 == 0) {
    traceln("slot " + tIndex + "  ok=" + lstmCallsOk + "  fail=" + lstmCallsFailed
            + "  qos=" + qosActionsTotal
            + "  before=" + String.format(java.util.Locale.US, "%.2f", overflowBefore)
            + "  after="  + String.format(java.util.Locale.US, "%.2f", overflowAfter));
}
tIndex++;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1777326908547</Id>
					<Name><![CDATA[generateTrafficForSlot]]></Name>
					<X>180</X><Y>390</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// Hour and day-of-week from tIndex
double totalMinutes   = tIndex * intervalMin;
double hour           = (totalMinutes / 60.0) % 24.0;
int    dayOfWeek      = ((int)(totalMinutes / (60.0 * 24.0))) % 7;

// Diurnal: cosine peak at 14:00, range ~[0.3, 1.3]
double diurnal = 0.8 + 0.5 * Math.cos((hour - 14.0) * Math.PI / 12.0);
// Weekly: 0.7 on weekend (Sat=5, Sun=6), 1.0 on weekday
double weekly  = (dayOfWeek >= 5) ? 0.7 : 1.0;

for (int i = 0; i < N; i++) {
    for (int j = 0; j < N; j++) {
        if (i == j) { trafficMatrix[i][j] = 0.0; continue; }

        // AR(1) burst state update
        double innov = NOISE_SD * 0.5 * rng.nextGaussian();
        burstState[i][j] = BURST_AR * burstState[i][j] + innov;

        // Multiplicative Gaussian noise
        double noise = 1.0 + NOISE_SD * rng.nextGaussian();

        double y = baseMatrix[i][j] * diurnal * weekly * noise * eventMultiplier[i][j];
        if (burstState[i][j] > 0) y += burstState[i][j];
        if (y < 0) y = 0;
        trafficMatrix[i][j] = y;
    }
}]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1777326985644</Id>
					<Name><![CDATA[writeCsvRow]]></Name>
					<X>380</X><Y>390</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (writer == null) return;

// ISO timestamp based on tIndex * intervalMin minutes offset from start
long millis = (long)(tIndex * intervalMin * 60.0 * 1000.0);
java.time.LocalDateTime ts =
        java.time.LocalDateTime.of(2025, 1, 1, 0, 0).plusMinutes((long)(tIndex * intervalMin));

StringBuilder sb = new StringBuilder();
sb.append(tIndex).append(",").append(ts.toString());
for (int i = 0; i < N; i++) {
    for (int j = 0; j < N; j++) {
        sb.append(",").append(String.format(java.util.Locale.US, "%.6f", trafficMatrix[i][j]));
    }
}
writer.println(sb.toString());
// flush every 50 rows to bound memory
if (tIndex % 50 == 0) writer.flush();]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1777327021166</Id>
					<Name><![CDATA[openCsv]]></Name>
					<X>90</X><Y>440</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[try {
    java.io.File f = new java.io.File("traffic_matrix.csv").getAbsoluteFile();
    writer = new java.io.PrintWriter(new java.io.FileWriter(f, false));
    // header
    StringBuilder hdr = new StringBuilder("t_index,timestamp");
    for (int i = 0; i < N; i++)
        for (int j = 0; j < N; j++)
            hdr.append(",y_").append(i).append("_").append(j);
    writer.println(hdr.toString());
    writer.flush();
    traceln("opened CSV at " + f.getAbsolutePath());
} catch (Exception e) {
    traceln("CSV open failed: " + e.getMessage());
}]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1777327055452</Id>
					<Name><![CDATA[closeCsv]]></Name>
					<X>260</X><Y>440</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (writer != null) {
    writer.flush();
    writer.close();
    writer = null;
    traceln("closed CSV");
}]]></Body>
				</Function>
			
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1888100000001</Id>
					<Name><![CDATA[callPredictionService]]></Name>
					<X>540</X><Y>390</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// POST the raw traffic vector to /ingest. Service returns prediction +
// congestion_flags. We parse destination indices into `overloadedDests`.
// Any failure leaves overloadedDests empty so the simulation keeps running.

StringBuilder body = new StringBuilder("{\"vector\":[");
boolean first = true;
for (int i = 0; i < N; i++) {
    for (int j = 0; j < N; j++) {
        if (!first) body.append(",");
        body.append(String.format(java.util.Locale.US, "%.6f", rawTrafficMatrix[i][j]));
        first = false;
    }
}
body.append("],\"timestamp\":").append((double) tIndex);
body.append(",\"do_partial_fit\":true}");

try {
    java.net.http.HttpRequest req = java.net.http.HttpRequest.newBuilder()
            .uri(java.net.URI.create(lstmServiceUrl + "/ingest"))
            .timeout(httpTimeout)
            .header("Content-Type", "application/json")
            .POST(java.net.http.HttpRequest.BodyPublishers.ofString(body.toString()))
            .build();
    java.net.http.HttpResponse<String> resp =
            httpClient.send(req, java.net.http.HttpResponse.BodyHandlers.ofString());
    if (resp.statusCode() / 100 != 2) {
        lstmCallsFailed++;
        if (lstmCallsFailed <= 3)
            traceln("[t=" + tIndex + "] LSTM HTTP " + resp.statusCode());
        return;
    }
    String json = resp.body();
    int flagsStart = json.indexOf("\"congestion_flags\"");
    if (flagsStart >= 0) {
        int arrOpen  = json.indexOf("[", flagsStart);
        int arrClose = matchingBracket(json, arrOpen);
        if (arrOpen >= 0 && arrClose > arrOpen) {
            String flagsArr = json.substring(arrOpen + 1, arrClose);
            java.util.regex.Matcher m = java.util.regex.Pattern.compile(
                    "\"destination\"\\s*:\\s*(\\d+)").matcher(flagsArr);
            while (m.find()) {
                overloadedDests.add(Integer.parseInt(m.group(1)));
            }
        }
    }
    lstmCallsOk++;
} catch (Exception e) {
    lstmCallsFailed++;
    if (lstmCallsFailed <= 3)
        traceln("[t=" + tIndex + "] LSTM call failed: " + e.getMessage());
}]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1888100000002</Id>
					<Name><![CDATA[applyQosAction]]></Name>
					<X>700</X><Y>390</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// Modify `trafficMatrix` in place based on the chosen QoS strategy.
//   NoAction   \u2014 do nothing (sanity check)
//   RateLimit  \u2014 throttle inbound to flagged dests by 50%
//   Reroute    \u2014 shift 30% of flagged-dest inbound to the least-loaded peer
//   Hybrid     \u2014 reroute first; rate-limit anything still overloaded

if (overloadedDests.isEmpty()) return;

final double THROTTLE = 0.5;
final double REROUTE  = 0.30;

double[] inbound = new double[N];
for (int i = 0; i < N; i++)
    for (int j = 0; j < N; j++)
        inbound[j] += trafficMatrix[i][j];

if (qosStrategy.equalsIgnoreCase("NoAction")) return;

if (qosStrategy.equalsIgnoreCase("Reroute") || qosStrategy.equalsIgnoreCase("Hybrid")) {
    java.util.Set<Integer> overSet = new java.util.HashSet<Integer>(overloadedDests);
    for (int j : overloadedDests) {
        int alt = -1;
        double minLoad = Double.POSITIVE_INFINITY;
        for (int k = 0; k < N; k++) {
            if (k == j || overSet.contains(k)) continue;
            if (inbound[k] < minLoad) { minLoad = inbound[k]; alt = k; }
        }
        if (alt < 0) continue;
        for (int i = 0; i < N; i++) {
            double moved = trafficMatrix[i][j] * REROUTE;
            trafficMatrix[i][j]   -= moved;
            trafficMatrix[i][alt] += moved;
        }
        inbound[alt] += inbound[j] * REROUTE;
        inbound[j]   -= inbound[j] * REROUTE;
        qosActionsTotal++;
    }
}

if (qosStrategy.equalsIgnoreCase("RateLimit") || qosStrategy.equalsIgnoreCase("Hybrid")) {
    for (int k = 0; k < N; k++) inbound[k] = 0;
    for (int i = 0; i < N; i++)
        for (int j = 0; j < N; j++)
            inbound[j] += trafficMatrix[i][j];
    for (int j : overloadedDests) {
        if (inbound[j] <= nodeCapacity(j) * 0.95) continue;
        for (int i = 0; i < N; i++) trafficMatrix[i][j] *= THROTTLE;
        qosActionsTotal++;
    }
}]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1888100000003</Id>
					<Name><![CDATA[nodeCapacity]]></Name>
					<X>860</X><Y>390</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameters>
						<Parameter>
							<Id>1888100000004</Id>
							<Name><![CDATA[j]]></Name>
							<Type><![CDATA[int]]></Type>
						</Parameter>
					</Parameters>
					<Body><![CDATA[// Per-node capacity used for slot-level overflow accounting.
// Flat heuristic capacity proportional to node population, with a floor.
double base = (nodePopulation != null && j < nodePopulation.length) ? nodePopulation[j] : 0.5;
return Math.max(0.5, base * 3.5);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1888100000005</Id>
					<Name><![CDATA[matchingBracket]]></Name>
					<X>1020</X><Y>390</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameters>
						<Parameter>
							<Id>1888100000006</Id>
							<Name><![CDATA[s]]></Name>
							<Type><![CDATA[String]]></Type>
						</Parameter>
						<Parameter>
							<Id>1888100000007</Id>
							<Name><![CDATA[openIdx]]></Name>
							<Type><![CDATA[int]]></Type>
						</Parameter>
					</Parameters>
					<Body><![CDATA[if (openIdx < 0 || openIdx >= s.length() || s.charAt(openIdx) != '[') return -1;
int depth = 0;
for (int i = openIdx; i < s.length(); i++) {
    char c = s.charAt(i);
    if (c == '[') depth++;
    else if (c == ']') { depth--; if (depth == 0) return i; }
}
return -1;]]></Body>
				</Function>
